<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:id="@+id/notification_device_name"
        style="@style/NotificationBatteryTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="horizontal">

        <!-- Collapsed pill: icon + % only, on one line. The distinct
             left/right/case icons make the label unnecessary here, and dropping
             it stops the percentage from wrapping in the narrow collapsed width.
             The full LEFT/RIGHT/CASE labels live in the expanded layout. -->
        <FrameLayout
            android:id="@+id/notification_left_container"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_battery_pill">

            <ImageView
                android:id="@+id/notification_left_wave"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@null"
                android:scaleType="fitXY" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="6dp"
                android:paddingEnd="8dp">

                <ImageView
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:layout_marginEnd="4dp"
                    android:contentDescription="@string/left_bud"
                    android:src="@drawable/ic_earbud_left" />

                <TextView
                    android:id="@+id/notification_left_value"
                    style="@style/NotificationBatteryPillText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxLines="1" />
            </LinearLayout>
        </FrameLayout>

        <FrameLayout
            android:id="@+id/notification_right_container"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_battery_pill">

            <ImageView
                android:id="@+id/notification_right_wave"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@null"
                android:scaleType="fitXY" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="6dp"
                android:paddingEnd="8dp">

                <ImageView
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:layout_marginEnd="4dp"
                    android:contentDescription="@string/right_bud"
                    android:src="@drawable/ic_earbud_right" />

                <TextView
                    android:id="@+id/notification_right_value"
                    style="@style/NotificationBatteryPillText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxLines="1" />
            </LinearLayout>
        </FrameLayout>

        <FrameLayout
            android:id="@+id/notification_case_container"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:background="@drawable/bg_battery_pill">

            <ImageView
                android:id="@+id/notification_case_wave"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@null"
                android:scaleType="fitXY" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="6dp"
                android:paddingEnd="8dp">

                <ImageView
                    android:layout_width="11dp"
                    android:layout_height="11dp"
                    android:layout_marginEnd="4dp"
                    android:contentDescription="@string/case_label"
                    android:src="@drawable/ic_case" />

                <TextView
                    android:id="@+id/notification_case_value"
                    style="@style/NotificationBatteryPillText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxLines="1" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>
</LinearLayout>
